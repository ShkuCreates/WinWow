PORT=5000

# Your live frontend URL — required on Render so CORS allows checkout requests
FRONTEND_URL=https://your-frontend-url.vercel.app

# Etherscan API key — BACKEND ONLY (used to verify ETH & USDT payments on-chain)
# Get free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# --- Not needed for payment verification (ignore unless you add auth/DB later) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SESSION_SECRET=
